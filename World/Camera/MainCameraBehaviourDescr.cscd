		ShipFlyState: Plane
		StateDescr:
			PositionPoint: OxPositionJetPackTPUnderWing
			TargetPoint: OxTargetJetPackTPUnderWing
			CameraPositionSetting: CockpitPlane
			
	--
	Name: TPCargoViewState
	ShipVisualState: ThirdPersonView
	HotInput: Ship_Camera_Pos5 
	FlyStates:
